<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <system.webServer>
    <!--
      IIS Reverse Proxy สำหรับ PM2 (Port 3000)

      ⚠️ ต้องติดตั้งก่อน:
      1. URL Rewrite Module: https://www.iis.net/downloads/microsoft/url-rewrite
      2. Application Request Routing (ARR): https://www.iis.net/downloads/microsoft/application-request-routing
      3. เปิดใช้งาน ARR Proxy ใน IIS Manager

      ตรวจสอบ:
      - PM2 รันที่ port 3000: pm2 status
      - ARR Proxy enabled: Get-WebConfigurationProperty -PSPath "IIS:\" -Filter "system.webServer/proxy" -Name "enabled"
    -->

    <!-- URL Rewrite Rules -->
    <rewrite>
      <rules>
        <!-- Reverse Proxy ไปที่ PM2 บน localhost:3000 -->
        <rule name="ReverseProxy" stopProcessing="true">
          <match url="(.*)" />
          <action type="Rewrite" url="http://localhost:3000/{R:1}" />
        </rule>
      </rules>
    </rewrite>

    <!-- Security Headers -->
    <httpProtocol>
      <customHeaders>
        <add name="X-Frame-Options" value="SAMEORIGIN" />
        <add name="X-Content-Type-Options" value="nosniff" />
        <add name="X-XSS-Protection" value="1; mode=block" />
      </customHeaders>
    </httpProtocol>

    <!-- Error Pages -->
    <httpErrors errorMode="Detailed" />
  </system.webServer>
</configuration>
